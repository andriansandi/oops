{
  "name": "oops",
  "version": "0.1.0",
  "description": "Multi-Instance DB Management Hub — TUI for Cloudflare D1 & friends",
  "type": "module",
  "workspaces": ["packages/*"],
  "module": "src/index.ts",
  "bin": {
    "oops": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bun --bun tsc --noEmit && bun --bun tsc -p packages/core/tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@neondatabase/serverless": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "1.3.14",
    "typescript": "^5.4.0"
  }
}
